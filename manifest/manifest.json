{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.19/MicrosoftTeams.schema.json",
  "manifestVersion": "1.19",
  "version": "1.0.0",
  "id": "{{AGENT_IDENTITY_APP_ID}}",
  "developer": {
    "name": "Your Organization",
    "websiteUrl": "https://your-org.example.com",
    "privacyUrl": "https://your-org.example.com/privacy",
    "termsOfUseUrl": "https://your-org.example.com/terms"
  },
  "name": {
    "short": "My LangChain Agent",
    "full": "My LangChain Agent — Governed AI"
  },
  "description": {
    "short": "A governed LangChain agent registered with Agent 365.",
    "full": "A Python LangChain/LangGraph agent secured by Microsoft Entra Agent ID and observable through Agent 365 SDK. Replace this description with your agent's purpose."
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#0078D4",
  "copilotAgents": {
    "declarativeAgents": [
      {
        "id": "myAgent",
        "file": "declarativeAgent.json"
      }
    ]
  },
  "validDomains": [
    "your-app-service.azurewebsites.net"
  ]
}
