# === Entra Agent ID (required) ===
AZURE_TENANT_ID=your-tenant-id
AGENT_BLUEPRINT_APP_ID=your-blueprint-app-id
AGENT_IDENTITY_APP_ID=your-agent-identity-app-id

# Local dev only (App Service uses Managed Identity instead)
BLUEPRINT_CLIENT_SECRET=your-blueprint-secret

# === Azure AI Foundry ===
AZURE_AI_FOUNDRY_ENDPOINT=https://your-foundry.openai.azure.com/
AZURE_AI_FOUNDRY_DEPLOYMENT=gpt-5.4
AZURE_AI_FOUNDRY_API_VERSION=2025-01-01

# === App Insights (optional, auto-configured on App Service) ===
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...
